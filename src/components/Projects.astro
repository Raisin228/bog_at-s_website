---
const projects = [
  {
    title: 'Онбординг на RAG',
    description:
      'Корпоративный AI-ассистент для онбординга новых сотрудников. Отвечает на вопросы по внутренней документации, сокращает время адаптации.',
    stack: ['Python', 'FastAPI', 'LLM', 'RAG', 'PostgreSQL'],
    href: 'https://github.com/Raisin228',
  },
  {
    title: 'Анализатор IT-вакансий',
    description:
      'Мультиагентная система для парсинга и анализа рынка IT-вакансий. Выявляет тренды, сравнивает предложения по регионам и стеку.',
    stack: ['Python', 'Multi-agent', 'LLM', 'Redis', 'Celery'],
    href: 'https://github.com/Raisin228',
  },
  {
    title: 'Соцсеть на FastAPI',
    description:
      'REST API для социальной сети: аутентификация, лента, подписки, уведомления. Продакшен-конфигурация с Docker и Celery-воркерами.',
    stack: ['FastAPI', 'PostgreSQL', 'Redis', 'Docker', 'Celery'],
    href: 'https://github.com/Raisin228',
  },
];
---

<section id="projects">
  <div class="container">
    <span class="section-label reveal">Проекты</span>
    <h2 class="section-title reveal" data-delay="1">Что я строю</h2>

    <ul class="projects-grid">
      {projects.map((p, i) => (
        <li class="card reveal" data-delay={String(i + 1)}>
          <a href={p.href} target="_blank" rel="noopener noreferrer">
            <div class="card-top">
              <span class="card-num">0{i + 1}</span>
              <svg class="card-arrow" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 13L13 3M13 3H6M13 3v7"></path>
              </svg>
            </div>
            <h3 class="card-title">{p.title}</h3>
            <p class="card-desc">{p.description}</p>
            <ul class="card-stack">
              {p.stack.map((tag) => <li>{tag}</li>)}
            </ul>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .projects-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card a {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 28px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .card a:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 60px var(--accent-glow);
    border-color: rgba(var(--accent-rgb), 0.3);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .card-num {
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--accent);
  }

  .card-arrow {
    color: var(--muted);
    transition: transform 0.25s ease, color 0.25s ease;
  }

  .card a:hover .card-arrow {
    transform: translate(3px, -3px);
    color: var(--accent);
  }

  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 20px;
  }

  .card-stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .card-stack li {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 4px;
    background: var(--accent-glow);
    color: var(--accent);
  }

  @media (max-width: 960px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
