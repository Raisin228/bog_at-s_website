            </svg>
          </span>
          <span class="contact-info">
            <b>GitHub</b>
            <small>Raisin228</small>
          </span>
          <span class="contact-arrow">↗</span>
        </a>

        <a href="mailto:bogdanatrosenko@gmail.com" class="contact-btn">
          <span class="contact-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </span>
          <span class="contact-info">
            <b>Email</b>
            <small>bogdanatrosenko@gmail.com</small>
          </span>
          <span class="contact-arrow">↗</span>
        </a>

        <span class="contact-btn contact-btn--disabled">
          <span class="contact-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          </span>
          <span class="contact-info">
            <b>Telegram</b>
            <small>скоро</small>
          </span>
          <span class="contact-arrow">—</span>
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .contacts {
    padding: 80px 0 96px;
    border-top: 1px solid var(--border);
  }

  .contacts-inner {
    max-width: 560px;
  }

  .contacts-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .contacts-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 44px;
  }

  .contacts-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .contact-btn:not(.contact-btn--disabled):hover {
    transform: translateX(6px);
    border-color: rgba(var(--accent-rgb), 0.4);
    box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
  }

  .contact-btn--disabled {
    opacity: 0.4;
    cursor: default;
  }

  .contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .contact-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .contact-info b {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .contact-info small {
    font-size: 0.78rem;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-arrow {
    color: var(--muted);
    font-size: 0.9rem;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }

  .contact-btn:not(.contact-btn--disabled):hover .contact-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
</style>
