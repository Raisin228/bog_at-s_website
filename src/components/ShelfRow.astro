---
interface Card {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  visual: string;
}

interface Props {
  title: string;
  cards: Card[];
  id?: string;
}

const { title, cards, id } = Astro.props;
---

<section class="shelf" id={id} data-shelf>
  <div class="shelf-header container">
    <h2 class="shelf-title reveal">{title}</h2>
    <div class="shelf-arrows" aria-hidden="true">
      <button class="arrow" data-dir="-1" data-scroll aria-label="Прокрутить назад">‹</button>
      <button class="arrow" data-dir="1" data-scroll aria-label="Прокрутить вперёд">›</button>
    </div>
  </div>

  <div class="shelf-track" data-track>
    {cards.map((card) => (
      <article class="card">
        <div class="card-poster">
          <span class="card-visual" aria-hidden="true">{card.visual}</span>
          {card.github && (
            <a
              href={card.github}
              target="_blank"
              rel="noopener noreferrer"
              class="card-github"
              aria-label={`GitHub: ${card.title}`}
            >
              GitHub ↗
            </a>
          )}
        </div>
        <div class="card-body">
          <h3 class="card-title">{card.title}</h3>
          <p class="card-desc">{card.description}</p>
          <ul class="card-tags" aria-label="Технологии">
            {card.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .shelf {
    padding: 48px 0 56px;
  }

  .shelf-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .shelf-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .shelf-arrows {
    display: flex;
    gap: 8px;
  }

  .arrow {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--muted);
    font-size: 1.3rem;
    cursor: pointer;
    display: grid;
    place-items: center;
    line-height: 1;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    padding-bottom: 2px;
  }

  .arrow:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
  }

  /* Horizontal scroll track */
  .shelf-track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    /* align first card with container content */
    padding-left: max(24px, calc((100vw - 1100px) / 2 + 24px));
    padding-right: max(24px, calc((100vw - 1100px) / 2 + 24px));
    padding-top: 16px;
    padding-bottom: 20px;
  }

  .shelf-track::-webkit-scrollbar { display: none; }

  /* Card */
  .card {
    flex-shrink: 0;
    width: 228px;
    scroll-snap-align: start;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    position: relative;
  }

  .card:hover {
    transform: scale(1.06) translateY(-4px);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.3);
    border-color: rgba(var(--accent-rgb), 0.3);
    z-index: 5;
  }

  /* Poster area */
  .card-poster {
    position: relative;
    height: 128px;
    background: linear-gradient(135deg,
      rgba(var(--accent-rgb), 0.28) 0%,
      rgba(var(--accent-rgb), 0.06) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .card-visual {
    font-size: 3rem;
    line-height: 1;
    user-select: none;
    filter: drop-shadow(0 2px 12px rgba(0, 0, 0, 0.25));
  }

  .card-github {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(0, 0, 0, 0.5);
    padding: 3px 9px;
    border-radius: 4px;
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.2s;
    letter-spacing: 0.04em;
  }

  .card:hover .card-github { opacity: 1; }

  /* Card content */
  .card-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.76rem;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }

  .card-tags li {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(var(--accent-rgb), 0.25);
    border-radius: 3px;
    padding: 2px 6px;
  }
</style>

<script>
  document.querySelectorAll('[data-shelf]').forEach((shelf) => {
    const track = shelf.querySelector('[data-track]');
    if (!track) return;
    shelf.querySelectorAll('[data-scroll]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = parseInt(btn.getAttribute('data-dir') ?? '0');
        track.scrollBy({ left: dir * 256, behavior: 'smooth' });
      });
    });
  });
</script>
