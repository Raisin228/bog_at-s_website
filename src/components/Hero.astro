---
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="container hero-content">
    <p class="hero-meta">★ На основе вашего поиска: <em>идеальный инженер</em></p>

    <h1 class="hero-name">Богдан<br />Атрошенко</h1>

    <ul class="hero-genres" aria-label="Специализации">
      <li>Python</li>
      <li>AI/ML</li>
      <li>RAG</li>
      <li>FastAPI</li>
    </ul>

    <p class="hero-tagline">Проектирует системы, которые думают</p>

    <p class="hero-rating">
      <span class="stars" aria-hidden="true">★★★★★</span>
      <strong>9.8 / 10</strong>
      <span class="rating-source">по версии ICPC</span>
    </p>

    <div class="hero-cta">
      <a class="btn btn--primary" href="#shelf-ai">▶ Подробнее</a>
      <button id="hire-btn" class="btn btn--outline">+ Добавить в команду</button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 55% 65% at 85% 15%, rgba(var(--accent-rgb), 0.14), transparent),
      radial-gradient(ellipse 40% 50% at 10% 85%, rgba(var(--accent-rgb), 0.07), transparent);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 110px;
    padding-bottom: 80px;
    max-width: 700px;
  }

  .hero-meta {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: 28px;
    letter-spacing: 0.04em;
    animation: fade-up 0.6s ease 0.1s both;
  }

  .hero-meta em {
    color: var(--accent);
    font-style: normal;
  }

  .hero-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3.2rem, 9vw, 6.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--text);
    margin-bottom: 32px;
    animation: fade-up 0.7s ease 0.2s both;
  }

  .hero-genres {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
    animation: fade-up 0.7s ease 0.3s both;
  }

  .hero-genres li {
    padding: 4px 14px;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  .hero-tagline {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 18px;
    animation: fade-up 0.7s ease 0.35s both;
  }

  .hero-rating {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 44px;
    animation: fade-up 0.7s ease 0.42s both;
  }

  .stars {
    color: #F5C518;
    letter-spacing: 2px;
    font-size: 0.95rem;
  }

  .hero-rating strong {
    color: var(--text);
    font-weight: 600;
  }

  .rating-source {
    font-size: 0.72rem;
    opacity: 0.55;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    animation: fade-up 0.7s ease 0.5s both;
  }

  @media (max-width: 480px) {
    .hero-cta { flex-direction: column; }
    .hero-cta .btn { justify-content: center; }
  }
</style>

<script>
  const btn = document.getElementById('hire-btn');
  const KEY = 'hired';

  function updateBtn() {
    if (!btn) return;
    const hired = localStorage.getItem(KEY);
    btn.textContent = hired ? '✓ В команде' : '+ Добавить в команду';
    if (hired) {
      btn.style.borderColor = 'var(--accent)';
      btn.style.color = 'var(--accent)';
    } else {
      btn.style.borderColor = '';
      btn.style.color = '';
    }
  }

  updateBtn();

  btn?.addEventListener('click', () => {
    if (localStorage.getItem(KEY)) localStorage.removeItem(KEY);
    else localStorage.setItem(KEY, '1');
    updateBtn();
  });
</script>
